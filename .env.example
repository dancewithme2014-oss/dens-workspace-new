RESEND_API_KEY=re_your_api_key
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=Den's Workspace <contact@your-verified-domain.com>

# Supabase editorial platform
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=server_only_service_role_key

# Server-to-server integrations
N8N_INTEGRATION_SECRET=generate_a_long_random_secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# n8n environment variables used by the all-in-one workflow
DW_RSS_FEED_URL=https://example.com/feed.xml
DENS_SITE_URL=http://host.docker.internal:3000
SUPABASE_URL=https://your-project.supabase.co

# Telegram approval
TELEGRAM_BOT_TOKEN=store_in_n8n_credentials_when_possible
TELEGRAM_APPROVAL_CHAT_ID=replace_after_creating_private_group
TELEGRAM_RU_TOPIC_ID=replace_after_creating_ru_topic
TELEGRAM_EN_TOPIC_ID=replace_after_creating_en_topic
TELEGRAM_ALLOWED_USER_IDS=123456789

# AI editorial call (configure in n8n Credentials when possible)
EDITORIAL_LLM_API_KEY=replace_in_n8n_credentials
